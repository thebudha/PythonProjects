from datetime import datetime
import time

dt1 = datetime(2018, 1, 1)
print(dt1)
dt2 = datetime.now()
print(dt2)
dt = datetime.strptime("2018-01-01", "%Y-%m-%d") #Converts a string to a datetime object based on the specified format
print(dt)
dt = datetime.fromtimestamp(time.time()) #Converts a timestamp to a datetime object
print(f"{dt.year}/{dt.month}")
print(dt.strftime("%B %d, %Y")) #Formats the datetime object as a string based on the specified format

print(dt1 < dt2) #True